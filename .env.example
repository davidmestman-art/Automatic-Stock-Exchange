# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Get them at: https://app.alpaca.markets → Paper Trading → API Keys
#
# With these set the engine automatically routes orders through Alpaca paper.
# Leave blank (or delete the file) to run in pure local simulation mode.

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# ── Live trading (optional, real money — use with caution) ────────────────────
# Switch to your live keys and set PAPER_TRADING=false in config.py.
# Live base URL: https://api.alpaca.markets  (set in config.py paper_trading=False)

# ── Dashboard authentication ──────────────────────────────────────────────────
# Set both to enable the login page. Leave blank to run without authentication.
DASH_USERNAME=admin
DASH_PASSWORD=changeme

# Secret key for signing session cookies. Set this to a long random string so
# sessions survive server restarts. Leave blank to auto-generate (users must
# log in again each time the server restarts).
DASH_SECRET_KEY=
